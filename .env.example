# Convex
CONVEX_DEPLOYMENT=
SITE_URL=http://localhost:5173

# Auth / email
DEV_MAGIC_LINK=true
VITE_DEV_MAGIC_LINK=true
RESEND_API_KEY=
RESEND_FROM=QRButik <no-reply@qrbutik.se>

# Stripe — secrets are stored in Convex dev (not here). Bootstrap with:
#   npm run stripe:sandbox   # first time: provision Test Mode keys via CLI
#   npm run stripe:setup     # product/price + push env to Convex
#   npm run stripe:listen    # forward webhooks while testing checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=

# Playwright E2E (optional overrides)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_CONVEX_SITE_URL=https://your-deployment.convex.site
# STRIPE_E2E=true
