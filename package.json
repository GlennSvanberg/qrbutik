{
  "name": "qrbutik",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "npx convex dev",
    "prebuild": "node scripts/generate-pseo-files.mjs",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:convex": "vitest run --project convex",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test && npm run test:e2e",
    "stripe": "node node_modules/@stripe/cli/bin/shim.js",
    "stripe:sandbox": "node node_modules/@stripe/cli/bin/shim.js sandbox create --from-git --non-interactive",
    "stripe:claim": "node node_modules/@stripe/cli/bin/shim.js sandbox claim",
    "stripe:login": "node node_modules/@stripe/cli/bin/shim.js login",
    "stripe:setup": "node scripts/stripe-bootstrap.mjs",
    "stripe:listen": "node scripts/stripe-listen.mjs",
    "demo:seed": "npx convex run demoSeed:ensureDemoShop",
    "video:dev": "npm run dev --prefix remotion",
    "video:render": "npm run render --prefix remotion"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.10",
    "@convex-dev/react-query": "^0.0.0-alpha.11",
    "@tanstack/react-query": "^5.89.0",
    "@tanstack/react-router": "^1.132.2",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.132.2",
    "better-auth": "^1.4.9",
    "convex": "^1.31.0",
    "convex-helpers": "^0.1.119",
    "exceljs": "^4.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "resend": "^6.7.0",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.55.0",
    "@stripe/cli": "^1.42.13",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/eslint-config": "^0.3.2",
    "@types/node": "^25.0.9",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "~9.2.1",
    "convex-test": "^0.0.53",
    "eslint": "^9.39.2",
    "nitro": "^3.0.1-alpha.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^6.0.1",
    "vitest": "^3.2.4"
  }
}
